{
  "uid": "kubecenter-node-detail",
  "title": "KubeCenter: Node Detail",
  "tags": ["kubecenter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      { "name": "node", "type": "custom", "current": { "text": "", "value": "" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node.*\"}[5m])) * 100)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 2,
      "title": "Memory Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=~\"$node.*\"} / node_memory_MemTotal_bytes{instance=~\"$node.*\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 3,
      "title": "Disk Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "100 - (node_filesystem_avail_bytes{instance=~\"$node.*\",mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{instance=~\"$node.*\",mountpoint=\"/\",fstype!=\"rootfs\"} * 100)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 4,
      "title": "Pod Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 6 },
      "targets": [{ "expr": "count(kube_pod_info{node=\"$node\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 5,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [{ "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$node.*\"}[5m])) * 100)", "refId": "A", "legendFormat": "CPU %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=~\"$node.*\"} / node_memory_MemTotal_bytes{instance=~\"$node.*\"})", "refId": "A", "legendFormat": "Memory %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ]
}
