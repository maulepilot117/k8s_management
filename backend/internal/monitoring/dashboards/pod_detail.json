{
  "uid": "kubecenter-pod-detail",
  "title": "KubeCenter: Pod Detail",
  "tags": ["kubecenter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      { "name": "namespace", "type": "custom", "current": { "text": "default", "value": "default" } },
      { "name": "pod", "type": "custom", "current": { "text": "", "value": "" } }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\",pod=\"$pod\",namespace=\"$namespace\"}[5m])) by (container)", "refId": "A", "legendFormat": "{{container}}" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 2,
      "title": "Memory Working Set by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{container!=\"\",pod=\"$pod\",namespace=\"$namespace\"}) by (container)", "refId": "A", "legendFormat": "{{container}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 3,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(container_network_receive_bytes_total{pod=\"$pod\",namespace=\"$namespace\"}[5m]))", "refId": "A", "legendFormat": "Received" },
        { "expr": "sum(rate(container_network_transmit_bytes_total{pod=\"$pod\",namespace=\"$namespace\"}[5m]))", "refId": "B", "legendFormat": "Transmitted" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 4,
      "title": "Container Restarts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(kube_pod_container_status_restarts_total{pod=\"$pod\",namespace=\"$namespace\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 5,
      "title": "CPU Throttling",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [{ "expr": "sum(rate(container_cpu_cfs_throttled_seconds_total{container!=\"\",pod=\"$pod\",namespace=\"$namespace\"}[5m])) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } } }
    }
  ]
}
