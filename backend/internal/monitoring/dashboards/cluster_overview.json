{
  "uid": "kubecenter-cluster-overview",
  "title": "KubeCenter: Cluster Overview",
  "tags": ["kubecenter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 0,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "count(kube_node_info)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Total Pods",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "count(kube_pod_info)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 3,
      "title": "Running Pods",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Running\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 4,
      "title": "Failed Pods",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Failed\"}) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 5,
      "title": "Cluster CPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 6,
      "title": "Cluster Memory Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "100 * (1 - sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } } }
    },
    {
      "id": 7,
      "title": "Top 5 CPU-Consuming Pods",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [{ "expr": "topk(5, sum(rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])) by (pod, namespace))", "refId": "A", "legendFormat": "{{namespace}}/{{pod}}" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Top 5 Memory-Consuming Pods",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [{ "expr": "topk(5, sum(container_memory_working_set_bytes{container!=\"\"}) by (pod, namespace))", "refId": "A", "legendFormat": "{{namespace}}/{{pod}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
